rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own data, or read any user's public data
      allow read: if isAuthenticated();
      // Users can create/update their own profile
      allow create, update: if isOwner(userId);
      // Users can delete their own profile
      allow delete: if isOwner(userId);
    }
    
    // Jobs collection
    match /jobs/{jobId} {
      // Anyone authenticated can read open jobs
      allow read: if isAuthenticated();
      // Only the job owner (clientId) can create/update/delete their jobs
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource == null || resource.data.clientId == request.auth.uid);
    }
    
    // Job Applications/Proposals collections
    // Support multiple collection names that might be used (mobile app compatibility)
    match /job_applications/{applicationId} {
      // Providers can read their own proposals
      // Clients can read proposals for their jobs
      // Also support userId field (some apps might use userId instead of providerId)
      allow read: if isAuthenticated() && (
        (resource.data.providerId != null && resource.data.providerId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid) ||
        (resource.data.clientId != null && resource.data.clientId == request.auth.uid)
      );
      // Any authenticated user can create a proposal
      // Support both providerId and userId fields
      allow create: if isAuthenticated() && (
        (request.resource.data.providerId != null && request.resource.data.providerId == request.auth.uid) ||
        (request.resource.data.userId != null && request.resource.data.userId == request.auth.uid)
      );
      // Providers can update their own proposals
      // Clients can update proposals for their jobs (to set isHired, status, etc.)
      allow update: if isAuthenticated() && (
        (resource.data.providerId != null && resource.data.providerId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid) ||
        (resource.data.clientId != null && resource.data.clientId == request.auth.uid)
      );
      // Only the provider who created it can delete their own proposal
      allow delete: if isAuthenticated() && (
        (resource.data.providerId != null && resource.data.providerId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid)
      );
    }
    
    match /proposals/{proposalId} {
      // Providers can read their own proposals
      // Clients can read proposals for their jobs
      // Also support userId field (some apps might use userId instead of providerId)
      allow read: if isAuthenticated() && (
        (resource.data.providerId != null && resource.data.providerId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid) ||
        (resource.data.clientId != null && resource.data.clientId == request.auth.uid)
      );
      // Any authenticated user can create a proposal
      // Support both providerId and userId fields
      allow create: if isAuthenticated() && (
        (request.resource.data.providerId != null && request.resource.data.providerId == request.auth.uid) ||
        (request.resource.data.userId != null && request.resource.data.userId == request.auth.uid)
      );
      // Providers can update their own proposals
      // Clients can update proposals for their jobs (to set isHired, status, etc.)
      allow update: if isAuthenticated() && (
        (resource.data.providerId != null && resource.data.providerId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid) ||
        (resource.data.clientId != null && resource.data.clientId == request.auth.uid)
      );
      // Only the provider who created it can delete their own proposal
      allow delete: if isAuthenticated() && (
        (resource.data.providerId != null && resource.data.providerId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid)
      );
    }
    
    match /applications/{applicationId} {
      // Providers can read their own proposals
      // Clients can read proposals for their jobs
      // Also support userId field (some apps might use userId instead of providerId)
      allow read: if isAuthenticated() && (
        (resource.data.providerId != null && resource.data.providerId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid) ||
        (resource.data.clientId != null && resource.data.clientId == request.auth.uid)
      );
      // Any authenticated user can create a proposal
      // Support both providerId and userId fields
      allow create: if isAuthenticated() && (
        (request.resource.data.providerId != null && request.resource.data.providerId == request.auth.uid) ||
        (request.resource.data.userId != null && request.resource.data.userId == request.auth.uid)
      );
      // Providers can update their own proposals
      // Clients can update proposals for their jobs (to set isHired, status, etc.)
      allow update: if isAuthenticated() && (
        (resource.data.providerId != null && resource.data.providerId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid) ||
        (resource.data.clientId != null && resource.data.clientId == request.auth.uid)
      );
      // Only the provider who created it can delete their own proposal
      allow delete: if isAuthenticated() && (
        (resource.data.providerId != null && resource.data.providerId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid)
      );
    }
    
    // Showcase work collection
    match /showcase_work/{userId}/submissions/{submissionId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isOwner(userId);
    }
    
    // Showcase bookmarks
    match /showcaseWorkBookmarks/{bookmarkId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // Messages/Chat rooms
    match /chatRooms/{chatRoomId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.participants.hasAny([request.auth.uid]) ||
         request.resource.data.participants.hasAny([request.auth.uid]));
    }
    
    match /chatRooms/{chatRoomId}/messages/{messageId} {
      allow read, write: if isAuthenticated() && 
        exists(/databases/$(database)/documents/chatRooms/$(chatRoomId)) &&
        (get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.participants.hasAny([request.auth.uid]));
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
